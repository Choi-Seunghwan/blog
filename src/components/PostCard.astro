---
import FormattedDate from './FormattedDate.astro';

export interface Props {
  index: number;
  post: {
    slug: string;
    body?: string;
    data: {
      title: string;
      description?: string;
      pubDate: Date;
      author?: string;
      tags?: string[];
      image?: string;
      externalLink?: string;
    };
  };
}

const { post, index } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const postUrl = post.data.externalLink || `${base}posts/${post.slug}/`;
const isExternal = !!post.data.externalLink;

// Extract excerpt from description or body
let excerpt = post.data.description || '';
if (!excerpt && post.body) {
  excerpt = post.body
    .replace(/^---[\s\S]*?---\s*/m, '')
    .replace(/^#+\s+.*/gm, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/```[\s\S]*?```/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`~]/g, '')
    .replace(/\n+/g, ' ')
    .trim()
    .slice(0, 150);
  if (excerpt.length >= 150) excerpt += '…';
}

// Estimate reading time (Korean ~350 chars/min, strip markdown syntax)
const plainText = (post.body || '')
  .replace(/^---[\s\S]*?---\s*/m, '')
  .replace(/```[\s\S]*?```/g, '')
  .replace(/!\[.*?\]\(.*?\)/g, '')
  .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
  .replace(/^#+\s+/gm, '')
  .replace(/[*_`~>|]/g, '')
  .replace(/\n+/g, ' ')
  .trim();
const readingMin = Math.max(1, Math.round(plainText.length / 700));

// Format date for ls -la style
const d = post.data.pubDate;
const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const lsDate = `${months[d.getMonth()]} ${String(d.getDate()).padStart(2, ' ')} ${d.getFullYear()}`;

// Line number (zero-padded)
const lineNum = String(index).padStart(2, '0');
---

<article class="post on-list">
  <a href={postUrl} class="post-card-link" target={isExternal ? "_blank" : undefined} rel={isExternal ? "noopener" : undefined}>
    {post.data.image && (
      <figure class="post-cover">
        <img src={post.data.image} alt={post.data.title} />
      </figure>
    )}
    <div class="post-card-body">
      <div class="post-ls-meta">
        <span class="ls-perms">-rw-r--r--</span>
        <span class="ls-author">{post.data.author || 'chuz'}</span>
        <span class="ls-size">{readingMin}min</span>
        <span class="ls-date">{lsDate}</span>
      </div>
      <h2 class="post-title"><span class="prompt">$ cat </span>{post.slug}.md</h2>
      <div class="post-title-display">{post.data.title}</div>
      {post.data.tags && post.data.tags.length > 0 && (
        <span class="post-tags">
          {post.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </span>
      )}
      {excerpt && (
        <p class="post-excerpt">{excerpt}</p>
      )}
    </div>
  </a>
</article>
